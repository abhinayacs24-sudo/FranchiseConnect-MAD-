<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#041022">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/site_logo"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/logo"
                android:contentDescription="Site Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="FranchiseConnect"
                android:textColor="#7fcbff"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registration"
            android:textColor="#eaf6ff"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Profile Photo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivProfilePreview"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@android:drawable/ic_menu_camera"
                app:civ_border_width="2dp"
                app:civ_border_color="#7fcbff" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Click to Upload Photo"
                android:textColor="#cfefff"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:textStyle="italic" />
        </LinearLayout>

        <!-- Name Fields -->
        <TextView android:text="First Name *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <EditText android:id="@+id/etFirstName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="First Name" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <TextView android:text="Middle Name" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etMiddleName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Middle Name" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <TextView android:text="Last Name *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etLastName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Last Name" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <!-- Gender -->
        <TextView android:text="Gender *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <RadioGroup android:id="@+id/rgGender" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <RadioButton android:id="@+id/rbMale" android:text="Male" android:textColor="#FFFFFF" android:buttonTint="#58b0ff" />
            <RadioButton android:id="@+id/rbFemale" android:text="Female" android:textColor="#FFFFFF" android:buttonTint="#58b0ff" />
            <RadioButton android:id="@+id/rbOther" android:text="Other" android:textColor="#FFFFFF" android:buttonTint="#58b0ff" />
        </RadioGroup>

        <!-- DOB -->
        <TextView android:text="Date of Birth *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etDob" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="YYYY-MM-DD" android:focusable="false" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <!-- Location -->
        <TextView android:text="State *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <Spinner android:id="@+id/spState" android:layout_width="match_parent" android:layout_height="48dp" android:backgroundTint="#FFFFFF" />

        <TextView android:text="City *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etCity" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="City" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <TextView android:text="Pincode *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etPincode" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="6-digit" android:inputType="number" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <TextView android:text="Address *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etAddress" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Address" android:lines="2" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <!-- Education/Work -->
        <TextView android:text="Qualification *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <Spinner android:id="@+id/spQualification" android:layout_width="match_parent" android:layout_height="48dp" android:backgroundTint="#FFFFFF" />

        <TextView android:text="Occupation *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etOccupation" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Occupation" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <!-- Contact -->
        <TextView android:text="Mobile Number *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etMobile" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="10 digits" android:inputType="phone" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <TextView android:text="Email *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="example@email.com" android:inputType="textEmailAddress" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <!-- Password -->
        <TextView android:text="Password *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Password" android:inputType="textPassword" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <TextView android:text="Confirm Password *" android:textColor="#cfefff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
        <EditText android:id="@+id/etConfirmPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Confirm Password" android:inputType="textPassword" android:textColor="#FFFFFF" android:textColorHint="#4DFFFFFF" android:backgroundTint="#FFFFFF" />

        <!-- Buttons -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#1877ff"
            android:text="Register"
            android:textColor="#FFFFFF"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#1e293b"
            android:text="Clear"
            android:textColor="#FFFFFF"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/tvLoginLink"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Already have an account? Login"
            android:textColor="#7fcbff" />

    </LinearLayout>
</ScrollView>
