<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1C2D"
    android:orientation="vertical">

    <!-- NAVBAR -->
    <LinearLayout
        android:id="@+id/layoutNavbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#020617"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/logo"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="FranchiseConnect - Favorites"
            android:textColor="#60a5fa"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnFavDashboard"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#60a5fa"
            android:text="Dashboard"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnFavLogout"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#FF6347"
            android:text="Logout"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="No favorite brands yet"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFavorites"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp" />

</LinearLayout>
